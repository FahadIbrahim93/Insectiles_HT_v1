import { calculateGameSpeed, calculateSpawnInterval, shouldActivateFeverMode } from '../utils/gameRules';
import { advancePsyEffects, moveInsects, updateScreenShake } from '../utils/loop';
import { findTopTargetInLane } from '../utils/gameplay';

export interface Insect {
  id: number;
  lane: number;
  y: number;
  spriteIndex: number;
  speed: number;
  isFeverTarget?: boolean;
  cachedImage?: HTMLImageElement;
  frameIndex: number;
  frameCount: number;
  frameAdvanceCounter: number;
  frameAdvanceRate: number;
  useSpriteSheet: boolean;
  spriteRow: number;
  hitScale?: number;
  hitAlpha?: number;
  isHit?: boolean;
}

export interface PowerUp {
  id: number;
  lane: number;
  y: number;
  type: 'shield' | 'slowmo';
}

export interface PsyEffect {
  x: number;
  y: number;
  life: number;
  maxLife: number;
  hue: number;
}

export interface Particle {
  x: number;
  y: number;
  vx: number;
  vy: number;
  life: number;
  maxLife: number;
  color: string;
}

export interface ScorePopup {
  x: number;
  y: number;
  text: string;
  life: number;
  maxLife: number;
  scale: number;
  color: string;
}

export interface GameEngineConfig {
  laneCount: number;
  tileHeight: number;
  initialSpeed: number;
  speedIncrement: number;
  maxSpeed: number;
  feverThreshold: number;
}

export interface EngineCallbacks {
  getScore: () => number;
  getIsFeverMode: () => boolean;
  getIsPlaying: () => boolean;
  getGameOver: () => boolean;
  getIsSlowMo: () => boolean;
  getSoundEnabled: () => boolean;
  setFeverMode: (active: boolean) => void;
  addScore: (points: number) => void;
  setGameOver: (over: boolean) => void;
  addLeaderboardScore: (score: number) => void;
  recordHit: () => number;
  recordMiss: () => void;
  consumeShield: () => boolean;
  activateShield: () => void;
  activateSlowMo: (durationMs: number) => void;
  playFeverActivation: () => void;
  playTapSound: (lane: number, isFever: boolean) => void;
  playErrorSound: () => void;
  triggerHaptic: (pattern?: number | number[]) => void;
  getReducedMotion: () => boolean;
  stopBgm: () => void;
  onFrame?: (timestamp: number) => void;
  onMultiplierIncrease?: (multiplier: number) => void;
}

export class GameEngine {
  private config: GameEngineConfig;
  private callbacks: EngineCallbacks;
  private canvas: HTMLCanvasElement;
  private images: HTMLImageElement[];

  private insects: Insect[] = [];
  private powerUps: PowerUp[] = [];
  private psyEffects: PsyEffect[] = [];
  private particles: Particle[] = [];
  private scorePopups: ScorePopup[] = [];
  private speed: number;
  private frames = 0;
  private lastSpawnFrame = 0;
  private lastPowerUpFrame = 0;
  private hue = 0;
  private entityIdCounter = 0;
  private bgIndex: number;
  private shake = 0;

  private static readonly SPRITE_FALLING_START = 12;
  private static readonly SPRITE_FEVER_START = 12;
  private static readonly SPRITE_COUNT = 4;

  private static readonly WALK_FRAME_COUNT = 8;
  private static readonly WALK_FRAME_RATE = 5;
  private static readonly WALK_SPRITE_ROWS = 4;
  private static readonly WALK_SPRITE_PATH = 'ant-walk-cycle.svg';

  private static readonly LANE_COLORS = [
    'rgba(255,100,150,ALPHA)',
    'rgba(100,200,255,ALPHA)',
    'rgba(150,255,150,ALPHA)',
    'rgba(255,220,100,ALPHA)',
  ];

  private static readonly MAX_PARTICLES = 280;
  private particlePool: Particle[] = [];

  private requestRef: number | undefined;
  private isRunning = false;

  constructor(canvas: HTMLCanvasElement, images: HTMLImageElement[], config: GameEngineConfig, callbacks: EngineCallbacks) {
    this.canvas = canvas;
    this.images = images;
    this.config = config;
    this.callbacks = callbacks;
    this.speed = config.initialSpeed;
    this.bgIndex = Math.floor(Math.random() * 4) + 4;
  }

  start(): void {
    this.stop();
    this.reset();
    this.isRunning = true;
    this.loop();
  }

  stop(): void {
    this.isRunning = false;
    if (this.requestRef !== undefined) {
      cancelAnimationFrame(this.requestRef);
      this.requestRef = undefined;
    }
  }

  reset(): void {
    this.insects = [];
    this.powerUps = [];
    this.psyEffects = [];
    this.particles = [];
    this.particlePool = [];
    this.scorePopups = [];
    this.speed = this.config.initialSpeed;
    this.frames = 0;
    this.lastSpawnFrame = 0;
    this.lastPowerUpFrame = 0;
    this.hue = 0;
    this.entityIdCounter = 0;
    this.bgIndex = Math.floor(Math.random() * 4) + 4;
    this.shake = 0;
  }

  private loop(timestamp: number = performance.now()): void {
    if (!this.isRunning) return;

    const { getIsPlaying, getGameOver, getScore, getIsFeverMode } = this.callbacks;
    if (getGameOver() || !getIsPlaying()) {
      this.stop();
      return;
    }

    this.callbacks.onFrame?.(timestamp);
    this.frames++;
    this.hue = (this.hue + (getIsFeverMode() ? 8 : 1)) % 360;

    const score = getScore();
    const isFeverMode = getIsFeverMode();

    if (shouldActivateFeverMode(score, this.config.feverThreshold, isFeverMode)) {
      this.callbacks.setFeverMode(true);
      this.callbacks.playFeverActivation();
    }

    this.shake = updateScreenShake(this.shake, isFeverMode, this.frames);
    this.speed = calculateGameSpeed({
      score,
      initialSpeed: this.config.initialSpeed,
      speedIncrement: this.config.speedIncrement,
      maxSpeed: this.config.maxSpeed,
    });

    if (this.frames - this.lastSpawnFrame > calculateSpawnInterval({ isFeverMode, score })) {
      this.spawnInsect();
      this.lastSpawnFrame = this.frames;
    }

    if (this.frames - this.lastPowerUpFrame > 540) {
      this.spawnPowerUp();
      this.lastPowerUpFrame = this.frames;
    }

    const speedMultiplier = this.callbacks.getIsSlowMo() ? 0.55 : 1;
    const moved = moveInsects(this.insects, this.canvas.height, isFeverMode, this.config.tileHeight, speedMultiplier);
    this.insects = moved.insects;

    if (moved.reachedBottom && !isFeverMode) {
      if (this.callbacks.consumeShield()) {
        this.insects = this.insects.filter((ins) => ins.y < this.canvas.height);
        this.shake = 18;
      } else {
        this.callbacks.recordMiss();
        this.callbacks.setGameOver(true);
        this.callbacks.addLeaderboardScore(score);
        this.callbacks.playErrorSound();
        this.callbacks.stopBgm();
      }
    }

    this.advancePowerUps(speedMultiplier);
    this.psyEffects = advancePsyEffects(this.psyEffects);
    this.advanceParticles();
    this.advanceInsectAnimations();
    this.advanceScorePopups();

    this.draw();
    this.requestRef = requestAnimationFrame((nextTimestamp) => this.loop(nextTimestamp));
  }

  private spawnInsect(): void {
    const isFeverMode = this.callbacks.getIsFeverMode();
    const lane = Math.floor(Math.random() * this.config.laneCount);
    let spriteIndex = -1;
    let cachedImage: HTMLImageElement | undefined;
    let useSpriteSheet = false;

    if (isFeverMode) {
      spriteIndex = GameEngine.SPRITE_FEVER_START + Math.floor(Math.random() * GameEngine.SPRITE_COUNT);
      cachedImage = this.images[spriteIndex];
    } else {
      cachedImage = this.images.find((img) => img.src.includes(GameEngine.WALK_SPRITE_PATH));
      if (cachedImage) {
        useSpriteSheet = true;
      } else {
        spriteIndex = GameEngine.SPRITE_FALLING_START + Math.floor(Math.random() * GameEngine.SPRITE_COUNT);
        cachedImage = this.images[spriteIndex];
      }
    }

    this.insects.push({
      id: this.entityIdCounter++,
      lane,
      y: -this.config.tileHeight,
      spriteIndex,
      speed: this.speed * (isFeverMode ? 1.5 : 1),
      isFeverTarget: isFeverMode,
      cachedImage,
      frameIndex: 0,
      frameCount: GameEngine.WALK_FRAME_COUNT,
      frameAdvanceCounter: 0,
      frameAdvanceRate: GameEngine.WALK_FRAME_RATE,
      useSpriteSheet,
      spriteRow: lane % GameEngine.WALK_SPRITE_ROWS,
      hitScale: 1,
      hitAlpha: 1,
      isHit: false,
    });
  }

  private spawnPowerUp(): void {
    const lane = Math.floor(Math.random() * this.config.laneCount);
    const type: PowerUp['type'] = Math.random() > 0.5 ? 'shield' : 'slowmo';
    this.powerUps.push({ id: this.entityIdCounter++, lane, y: -this.config.tileHeight * 0.5, type });
  }

  private advancePowerUps(speedMultiplier: number): void {
    const fallSpeed = Math.max(2, this.speed * 0.7 * speedMultiplier);
    this.powerUps = this.powerUps
      .map(p => ({ ...p, y: p.y + fallSpeed }))
      .filter(p => p.y <= this.canvas.height + this.config.tileHeight);
  }

  private advanceParticles(): void {
    const next: Particle[] = [];
    for (const p of this.particles) {
      if (++p.life >= p.maxLife) {
        this.particlePool.push(p);
      } else {
        p.x += p.vx;
        p.y += p.vy;
        p.vy += 0.08;
        next.push(p);
      }
    }
    this.particles = next;
  }

  private advanceInsectAnimations(): void {
    const next: Insect[] = [];
    for (const insect of this.insects) {
      if (insect.isHit) {
        insect.hitAlpha = (insect.hitAlpha || 1) - 0.08;
        insect.hitScale = (insect.hitScale || 1) + 0.02;
        if (insect.hitAlpha <= 0) continue;
      } else {
        if (++insect.frameAdvanceCounter >= insect.frameAdvanceRate) {
          insect.frameAdvanceCounter = 0;
          insect.frameIndex = (insect.frameIndex + 1) % insect.frameCount;
        }
        if (this.frames % 6 === 0) this.createTrailParticle(insect);
      }
      next.push(insect);
    }
    this.insects = next;
  }

  private advanceScorePopups(): void {
    this.scorePopups = this.scorePopups
      .filter(p => ++p.life < p.maxLife)
      .map(p => ({ ...p, y: p.y - 1.5, scale: 1.3 - (p.life / p.maxLife) * 0.4 }));
  }

  private draw(): void {
    const ctx = this.canvas.getContext('2d');
    if (!ctx) return;

    const isFeverMode = this.callbacks.getIsFeverMode();
    const reducedMotion = this.callbacks.getReducedMotion();

    ctx.fillStyle = '#000';
    ctx.fillRect(0, 0, this.canvas.width, this.canvas.height);

    this.drawStrikeZone(ctx, isFeverMode);
    if (isFeverMode) this.drawFeverOverlay(ctx, reducedMotion);

    for (const insect of this.insects) this.drawInsect(ctx, insect, isFeverMode, reducedMotion);
    for (const powerUp of this.powerUps) this.drawPowerUp(ctx, powerUp, reducedMotion);
    for (const p of this.psyEffects) this.drawPsyEffect(ctx, p);
    for (const p of this.particles) this.drawParticle(ctx, p);
    for (const p of this.scorePopups) this.drawScorePopup(ctx, p, reducedMotion);
  }

  private drawStrikeZone(ctx: CanvasRenderingContext2D, isFeverMode: boolean): void {
    if (isFeverMode) return;
    const laneWidth = this.canvas.width / this.config.laneCount;
    const strikeZoneY = this.canvas.height - this.config.tileHeight;
    const pulseAlpha = 0.05 + Math.sin(this.frames * 0.08) * 0.02;

    ctx.fillStyle = `rgba(255, 255, 255, ${pulseAlpha})`;
    ctx.fillRect(0, strikeZoneY, this.canvas.width, this.config.tileHeight);

    for (const insect of this.insects) {
      if (insect.y > strikeZoneY - this.config.tileHeight && !insect.isHit) {
        ctx.fillStyle = GameEngine.LANE_COLORS[insect.lane % GameEngine.LANE_COLORS.length].replace('ALPHA', '0.15');
        ctx.fillRect(insect.lane * laneWidth, strikeZoneY, laneWidth, this.config.tileHeight);
      }
    }

    ctx.strokeStyle = 'rgba(255, 255, 255, 0.2)';
    ctx.lineWidth = 2;
    ctx.beginPath();
    ctx.moveTo(0, strikeZoneY);
    ctx.lineTo(this.canvas.width, strikeZoneY);
    ctx.stroke();
  }

  private drawFeverOverlay(ctx: CanvasRenderingContext2D, reducedMotion: boolean): void {
    const grad = ctx.createRadialGradient(
      this.canvas.width / 2, this.canvas.height / 2, 0,
      this.canvas.width / 2, this.canvas.height / 2, this.canvas.height
    );
    grad.addColorStop(0, `hsla(${this.hue}, 90%, 55%, ${reducedMotion ? 0.15 : 0.3})`);
    grad.addColorStop(0.5, `hsla(${(this.hue + 60) % 360}, 90%, 50%, ${reducedMotion ? 0.1 : 0.2})`);
    grad.addColorStop(1, `hsla(${(this.hue + 120) % 360}, 95%, 45%, ${reducedMotion ? 0.14 : 0.35})`);
    ctx.fillStyle = grad;
    ctx.fillRect(0, 0, this.canvas.width, this.canvas.height);

    if (!reducedMotion) {
      const pulse = 0.4 + Math.sin(this.frames * 0.2) * 0.2;
      ctx.strokeStyle = `hsla(${(this.hue + 180) % 360}, 100%, 70%, ${pulse})`;
      ctx.lineWidth = 8 + Math.sin(this.frames * 0.1) * 4;
      ctx.strokeRect(5, 5, this.canvas.width - 10, this.canvas.height - 10);
    }
  }

  private drawInsect(ctx: CanvasRenderingContext2D, insect: Insect, isFever: boolean, reducedMotion: boolean): void {
    const img = insect.cachedImage;
    if (!img) return;

    const laneWidth = this.canvas.width / this.config.laneCount;
    const size = this.config.tileHeight * (isFever ? 1.2 : 0.8);
    const wobble = reducedMotion ? 0 : Math.sin(this.frames * 0.1 + insect.id) * 5;

    // Shadow
    ctx.save();
    ctx.translate(insect.lane * laneWidth + laneWidth / 2, insect.y + this.config.tileHeight + 10);
    ctx.scale(Math.max(0.3, 1 - (insect.y / this.canvas.height) * 0.5), 0.3);
    ctx.beginPath();
    ctx.ellipse(0, 0, size * 0.6, size * 0.3, 0, 0, Math.PI * 2);
    ctx.fillStyle = 'rgba(0, 0, 0, 0.4)';
    ctx.fill();
    ctx.restore();

    ctx.save();
    ctx.translate(insect.lane * laneWidth + laneWidth / 2 + wobble, insect.y + this.config.tileHeight / 2);
    const pulse = reducedMotion ? 1 : 1 + Math.sin(this.frames * 0.15 + insect.id) * 0.05;
    ctx.scale(pulse, pulse);

    if (insect.isHit) {
      ctx.scale(insect.hitScale || 1, insect.hitScale || 1);
      ctx.globalAlpha = Math.max(0, insect.hitAlpha || 1);
    }

    if (isFever) {
      ctx.shadowBlur = 20;
      ctx.shadowColor = `hsla(${this.hue}, 100%, 50%, 1)`;
    }

    if (insect.useSpriteSheet && img.naturalWidth > 0) {
      const fw = img.naturalWidth / GameEngine.WALK_FRAME_COUNT;
      const fh = img.naturalHeight / GameEngine.WALK_SPRITE_ROWS;
      ctx.drawImage(img, insect.frameIndex * fw, insect.spriteRow * fh, fw, fh, -size / 2, -size / 2, size, size);
    } else {
      ctx.drawImage(img, -size / 2, -size / 2, size, size);
    }
    ctx.restore();
  }

  private drawPowerUp(ctx: CanvasRenderingContext2D, p: PowerUp, reducedMotion: boolean): void {
    const laneWidth = this.canvas.width / this.config.laneCount;
    ctx.save();
    ctx.translate(p.lane * laneWidth + laneWidth / 2, p.y + this.config.tileHeight * 0.2);
    if (!reducedMotion) ctx.rotate(this.frames * 0.04);
    ctx.font = '42px serif';
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    ctx.fillText(p.type === 'shield' ? '🛡️' : '🐌', 0, 0);
    ctx.restore();
  }

  private drawPsyEffect(ctx: CanvasRenderingContext2D, p: PsyEffect): void {
    const progress = p.life / p.maxLife;
    ctx.save();
    ctx.translate(p.x, p.y);
    ctx.globalAlpha = 1 - progress;
    ctx.rotate(progress * Math.PI * 2);
    ctx.font = `${30 + progress * 50}px Arial`;
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    ctx.fillText(['🍄', '🌀', '🧠', '✨', '🐜'][Math.floor(p.hue % 5)] || '✨', 0, 0);
    ctx.restore();
  }

  private drawParticle(ctx: CanvasRenderingContext2D, p: Particle): void {
    ctx.fillStyle = p.color.replace('ALPHA', (1 - p.life / p.maxLife).toFixed(2));
    ctx.fillRect(p.x, p.y, 3, 3);
  }

  private drawScorePopup(ctx: CanvasRenderingContext2D, p: ScorePopup, reducedMotion: boolean): void {
    ctx.save();
    ctx.translate(p.x, p.y);
    if (!reducedMotion) ctx.scale(p.scale, p.scale);
    ctx.globalAlpha = 1 - p.life / p.maxLife;
    ctx.font = 'bold 24px Arial';
    ctx.textAlign = 'center';
    ctx.fillStyle = p.color;
    ctx.shadowBlur = 4;
    ctx.shadowColor = 'rgba(0,0,0,0.5)';
    ctx.fillText(p.text, 0, 0);
    ctx.restore();
  }

  handleTap(lane: number): void {
    if (!this.callbacks.getIsPlaying() || this.callbacks.getGameOver()) return;

    const powerUp = this.powerUps.find(p => p.lane === lane);
    if (powerUp) {
      this.powerUps = this.powerUps.filter(p => p.id !== powerUp.id);
      powerUp.type === 'shield' ? this.callbacks.activateShield() : this.callbacks.activateSlowMo(5000);
      this.createExplosion(lane, powerUp.y, 'rgba(130,255,255,ALPHA)');
      if (this.callbacks.getSoundEnabled()) {
        this.callbacks.playTapSound(lane, true);
        this.callbacks.triggerHaptic([8, 20, 8]);
      }
      return;
    }

    const target = findTopTargetInLane(this.insects, lane);
    if (!target) {
      this.callbacks.recordMiss();
      this.callbacks.triggerHaptic(12);
      return;
    }

    const hitInsect = this.insects.find(ins => ins.id === target.id);
    if (hitInsect) {
      hitInsect.isHit = true;
      hitInsect.hitScale = 1.3;
      hitInsect.hitAlpha = 1;
    }

    const combo = this.callbacks.recordHit();
    if (combo > 1) this.callbacks.onMultiplierIncrease?.(combo);

    const isFever = this.callbacks.getIsFeverMode();
    const points = (isFever ? 200 : 100) * combo;
    this.callbacks.addScore(points);
    this.shake = isFever ? 15 : 5;

    const laneWidth = this.canvas.width / this.config.laneCount;
    const hitX = target.lane * laneWidth + laneWidth / 2;
    const hitY = target.y + this.config.tileHeight / 2;

    this.createPsyEffect(hitX, hitY);
    this.createExplosion(lane, target.y, isFever ? 'rgba(255,70,200,ALPHA)' : 'rgba(255,220,80,ALPHA)');
    this.createScorePopup(hitX, hitY, points, combo);

    if (this.callbacks.getSoundEnabled()) {
      this.callbacks.playTapSound(lane, isFever);
      this.callbacks.triggerHaptic(isFever ? [50] : (combo > 1 ? [30] : [15]));
    }
  }

  private emitParticle(p: Particle): void {
    if (this.particles.length >= GameEngine.MAX_PARTICLES) return;
    const reused = this.particlePool.pop();
    if (reused) {
      Object.assign(reused, p);
      this.particles.push(reused);
    } else {
      this.particles.push(p);
    }
  }

  private createPsyEffect(x: number, y: number): void {
    this.psyEffects.push({ x, y, life: 0, maxLife: 30, hue: Math.random() * 360 });
  }

  private createExplosion(lane: number, y: number, color: string): void {
    const laneWidth = this.canvas.width / this.config.laneCount;
    const cx = lane * laneWidth + laneWidth / 2;
    const cy = y + this.config.tileHeight * 0.4;
    const isFever = this.callbacks.getIsFeverMode();
    const count = isFever ? 24 : 16;

    for (let i = 0; i < count; i++) {
      const angle = (Math.PI * 2 * i) / count + Math.random() * 0.3;
      const speed = (isFever ? 2 : 1.5) + Math.random() * 3;
      const pColor = isFever ? `hsla(${(this.hue + i * 20) % 360}, 100%, 70%, ALPHA)` : (Math.random() > 0.3 ? GameEngine.LANE_COLORS[lane % 4]! : color);
      this.emitParticle({ x: cx, y: cy, vx: Math.cos(angle) * speed, vy: Math.sin(angle) * speed, life: 0, maxLife: 20 + Math.random() * 10, color: pColor });
    }
  }

  private createTrailParticle(insect: Insect): void {
    const laneWidth = this.canvas.width / this.config.laneCount;
    const isFever = this.callbacks.getIsFeverMode();
    const color = isFever ? `hsla(${(this.hue + insect.id * 30) % 360}, 100%, 70%, ALPHA)` : GameEngine.LANE_COLORS[insect.lane % 4]!;
    this.emitParticle({
      x: insect.lane * laneWidth + laneWidth / 2 + (Math.random() - 0.5) * 20,
      y: insect.y + this.config.tileHeight * 0.8,
      vx: (Math.random() - 0.5) * 0.5,
      vy: (isFever ? 0.5 : 0.3) + Math.random() * 0.5,
      life: 0,
      maxLife: isFever ? 18 : 12,
      color
    });
  }

  private createScorePopup(x: number, y: number, points: number, combo: number): void {
    const isFever = this.callbacks.getIsFeverMode();
    const text = isFever ? `${points} FEVER!` : (combo >= 3 ? `${points} x${combo}` : `+${points}`);
    const color = isFever ? '#ff46c8' : (combo >= 3 ? '#ffd700' : '#fff');
    this.scorePopups.push({ x, y, text, life: 0, maxLife: 40, scale: 1.3, color });
  }
}
